{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/scripts/adg-guardrail-hook.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(vercel deploy *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(fly deploy *)",
      "Bash(flyctl deploy *)",
      "Bash(npm publish *)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/credentials*)",
      "Edit(**/migrations/**)",
      "Edit(**/drizzle/**)"
    ]
  }
}
