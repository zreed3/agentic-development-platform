{
  "name": "agentic-development-governance",
  "version": "1.1.0",
  "private": true,
  "description": "Agentic Development Governance (ADG): a SQL-first, deny-by-default governance layer for agent-assisted software development with guardrails, append-only audit, AI-security evals, DORA metrics, and bounded context.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node scripts/backlog-db.mjs setup",
    "setup:demo": "node scripts/backlog-db.mjs setup --seed data/seed/backlog.demo.seed.json --with-audit",
    "backlog:validate": "node scripts/backlog-db.mjs validate",
    "backlog:export": "node scripts/backlog-db.mjs export",
    "backlog:list": "node scripts/backlog-db.mjs list",
    "backlog:next": "node scripts/backlog-db.mjs next",
    "backlog:show": "node scripts/backlog-db.mjs show",
    "backlog:claim": "node scripts/backlog-db.mjs claim",
    "backlog:start": "node scripts/backlog-db.mjs start",
    "backlog:block": "node scripts/backlog-db.mjs block",
    "backlog:complete": "node scripts/backlog-db.mjs complete",
    "backlog:verify": "node scripts/backlog-db.mjs verify",
    "backlog:fail": "node scripts/backlog-db.mjs fail",
    "backlog:release": "node scripts/backlog-db.mjs release",
    "backlog:active": "node scripts/backlog-db.mjs active",
    "work:classify": "node scripts/adg-work-classify.mjs classify",
    "adg:classify": "npm run work:classify",
    "adg:guard": "node scripts/adg-work-classify.mjs guard",
    "adg:install": "node scripts/adg-install.mjs install",
    "adg:update": "node scripts/adg-install.mjs update",
    "adg:install:status": "node scripts/adg-install.mjs status",
    "adg:doctor": "node scripts/adg-doctor.mjs",
    "adg:mcp": "node scripts/adg-mcp-server.mjs",
    "claude:generate": "node scripts/adg-claude-md.mjs",
    "claude:check": "node scripts/adg-claude-md.mjs --check",
    "adg:sync": "npm run setup",
    "adg:sync:demo": "npm run setup:demo",
    "adg:context": "npm run context:slice",
    "adg:validate": "npm run elicitation:validate && npm run ux:validate && npm run standards:validate && npm run deliverable:audit",
    "context:feature": "node scripts/agent-context.mjs feature",
    "context:item": "node scripts/agent-context.mjs item",
    "context:audit": "node scripts/agent-context.mjs audit",
    "agent:next": "node scripts/agent-context.mjs next",
    "agent:loop": "node scripts/agent-context.mjs loop",
    "test:agent-context": "node tooling/agent-context/test-agent-context.mjs",
    "test:adg-install": "node tooling/delivery-lanes/test-adg-install.mjs",
    "test:adg-install-claude": "node tooling/delivery-lanes/test-adg-install-claude.mjs",
    "test:adg-install-codex": "node tooling/delivery-lanes/test-adg-install-codex.mjs",
    "test:adg-as-code": "node tooling/adg-as-code/test-adg-as-code.mjs",
    "test:adg-hook": "node plugins/adg-governance/hooks/test-adg-guardrail-hook.mjs",
    "test:adg-codex-hook": "node plugins/adg-governance/.codex-plugin/hooks/test-adg-codex-pretool.mjs",
    "test:adg-mcp": "node tooling/adg-mcp/test-adg-mcp.mjs",
    "test:backlog-evidence-gate": "node tooling/backlog-evidence/test-evidence-tier-gate.mjs",
    "test:adg-doctor": "node tooling/conformance-doctor/test-adg-doctor.mjs",
    "audit:validate": "node scripts/validate-audit.mjs",
    "audit:record": "node scripts/record-audit.mjs",
    "guardrails:check": "node scripts/guardrail-check.mjs",
    "guardrails:toggle": "node scripts/adg-toggle-control.mjs",
    "test:adg-toggles": "node tooling/adg-as-code/test-adg-toggles.mjs",
    "test:adg-audit-chain": "node tooling/adg-as-code/test-adg-audit-chain.mjs",
    "agent:evals": "node scripts/run-agent-evals.mjs",
    "metrics:dora": "node scripts/dora-metrics.mjs",
    "elicitation:validate": "node scripts/adg-elicitation.mjs validate",
    "elicitation:packet": "node scripts/adg-elicitation.mjs packet",
    "elicitation:graph": "node scripts/adg-elicitation.mjs graph",
    "context:slice": "node scripts/adg-context.mjs slice",
    "ux:validate": "node scripts/adg-ux.mjs validate",
    "ux:packet": "node scripts/adg-ux.mjs packet",
    "ux:truth-pass": "node scripts/adg-ux.mjs truth-pass",
    "ux:downgrade": "node scripts/adg-ux.mjs downgrade",
    "standards:validate": "node scripts/adg-standards.mjs validate",
    "standards:matrix": "node scripts/adg-standards.mjs matrix",
    "deliverable:audit": "node scripts/adg-deliverable.mjs audit",
    "plugin:validate": "node scripts/adg-plugin.mjs validate",
    "maturity:validate": "node scripts/adg-maturity.mjs validate",
    "maturity:score": "node scripts/adg-maturity.mjs score",
    "maturity:report": "node scripts/adg-maturity.mjs report",
    "skills:validate": "node scripts/adg-skills.mjs validate",
    "site:build": "node -e \"const fs=require('fs'),path=require('path');const src='site',dst='dist-site';fs.rmSync(dst,{recursive:true,force:true});fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src)){fs.copyFileSync(path.join(src,f),path.join(dst,f));}console.log('dist-site/ built from site/');\"",
    "test:delivery-lanes": "node tooling/delivery-lanes/test-delivery-lanes.mjs",
    "ci:traceability": "npm run ci:governance",
    "ci:governance": "npm run adg:guard -- --event traceability --intent \"governance gate\" && npm run setup:demo && npm run backlog:validate && npm run audit:validate -- --quiet && npm run guardrails:check -- --quiet && npm run asset:lint -- --quiet && npm run agent:evals && npm run metrics:dora && npm run elicitation:validate && npm run elicitation:graph -- --feature S07 && npm run context:slice -- --feature S07 --workflow agentic-tooling && npm run ux:validate && npm run standards:validate && npm run deliverable:audit && npm run plugin:validate && npm run maturity:validate && npm run skills:validate && npm run test:delivery-lanes && npm run test:adg-install && npm run test:agent-context && npm run test:adg-as-code && npm run test:adg-hook && npm run test:adg-write-scope && npm run test:adg-toggles && npm run test:adg-audit-chain && npm run test:adg-quiet && npm run test:adg-asset-lint && npm run test:select-model && npm run test:governor && npm run test:subagent-gate && npm run test:loop-hooks && npm run test:sdk && npm run test:adg-cli && npm run test:backlog-evidence-gate && npm run adg:doctor -- --quiet && npm run test:adg-doctor && npm run test:adg-install-claude && npm run test:adg-install-codex && npm run test:adg-codex-hook && npm run test:adg-codex-lifecycle && npm run test:adg-mcp",
    "prepush": "npm run adg:guard -- --event github-push --intent \"GitHub update pre-push\" && npm run ci:governance",
    "dashboard:dev": "npm --prefix apps/dashboard run dev",
    "dashboard:build": "npm --prefix apps/dashboard run build",
    "dashboard:docker": "docker build -t adg-dashboard apps/dashboard && docker run --rm -p 3000:3000 -v \"$PWD:/repo:ro\" adg-dashboard",
    "test:adg-quiet": "node tooling/adg-as-code/test-adg-quiet.mjs",
    "asset:lint": "node scripts/asset-lint.mjs",
    "asset:lint:build": "cargo build --release --manifest-path tools/adg-asset-lint/Cargo.toml",
    "test:adg-asset-lint": "node tooling/adg-as-code/test-adg-asset-lint.mjs",
    "asset:lint:dist": "bash tools/adg-asset-lint/build-all.sh",
    "test:adg-write-scope": "node tooling/adg-as-code/test-adg-write-scope.mjs",
    "models:select": "node scripts/adg-models.mjs select",
    "models:tiers": "node scripts/adg-models.mjs tiers",
    "test:select-model": "node tooling/adg-as-code/test-select-model.mjs",
    "test:governor": "node tooling/adg-as-code/test-governor.mjs",
    "test:subagent-gate": "node tooling/adg-as-code/test-subagent-gate.mjs",
    "test:loop-hooks": "node tooling/adg-as-code/test-loop-hooks.mjs",
    "test:sdk": "node tooling/adg-as-code/test-sdk.mjs",
    "test:adg-codex-lifecycle": "node plugins/adg-governance/.codex-plugin/hooks/test-adg-codex-lifecycle.mjs",
    "adg:init": "node scripts/adg-init.mjs",
    "test:adg-cli": "node tooling/adg-as-code/test-adg-cli.mjs"
  },
  "author": "Zach Reeder (OtterBlock Pty Ltd) <zach+github@otterblock.com.au> (https://github.com/zreed3)",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  }
}
